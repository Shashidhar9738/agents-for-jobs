# Runtime logs and transient files
setup.log
!LOGFILE!
logs/
.env
config/n8n.local.credentials.json

# n8n runtime artifacts
n8n/node_modules/
n8n/package-lock.json
n8n/package.json

# General node artifacts
node_modules/

# Python caches
__pycache__/
*.pyc

# OS/editor noise
.DS_Store
Thumbs.db

# Candidate artifacts, resumes, and run output are tracked so a clone brings
# the complete working state across machines.
# NOTE: these contain personal data (names, contact details, work history).
# Keep this repository private once real resumes are added.

# Secrets stay out of git regardless: .env holds the provider API key and the
# vault key that decrypts stored portal passwords.
config/users.json
config/vault.json
config/candidates/*/previous/
