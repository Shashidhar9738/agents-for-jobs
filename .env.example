# Local n8n + workflow configuration
#
# Copy this to .env and fill in the blank values. .env is gitignored and must
# stay that way: it holds live API keys and the vault key that decrypts stored
# portal passwords. Never commit it, especially while this repo is public.
#
# Moving to another machine: copy this file to .env there, then transfer the
# blank values out-of-band (password manager, USB, direct file copy) - not
# through git.

# --- Secrets: fill these in per machine, never commit -----------------------

# AI provider (active provider is set in config/ai-models.json)
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Encrypts portal passwords in the credential vault.
# Must match the key the existing vault was encrypted with, or stored
# credentials cannot be decrypted.
JOB_AGENT_VAULT_KEY=

# Machine token for n8n -> pipeline calls
JOB_AGENT_API_TOKEN=

# n8n MCP access token (JWT issued by your n8n instance)
N8N_MCP_ACCESS_TOKEN=

# n8n owner account. n8n 1.x creates this in the browser on first launch;
# N8N_BASIC_AUTH_* is no longer used by n8n and is ignored.
N8N_USER=
N8N_PASSWORD=

# Gmail OAuth2 (Google Cloud Console -> Gmail API -> OAuth 2.0 Desktop app)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Non-secret configuration ----------------------------------------------

MINIMUM_MATCH_SCORE=80
NOTIFICATION_EMAIL=

# Host/port n8n binds to. The URLs below must point at the machine running
# n8n - change the IP when moving between desktop and laptop.
N8N_HOST=http://192.168.29.100
N8N_PORT=5678
N8N_EDITOR_BASE_URL=http://192.168.29.100:5678/
WEBHOOK_URL=http://192.168.29.100:5678/
N8N_MCP_URL=http://192.168.29.100:5678/mcp

N8N_LOCAL_CREDENTIALS_FILE=config\\n8n.local.credentials.json

N8N_SECURE_COOKIE=false

# Disables TLS certificate verification for Node. Only needed behind a TLS
# intercepting proxy; remove it if installs work without it.
NODE_TLS_REJECT_UNAUTHORIZED=0

# Set to allow self-registration; share the code with people who may sign up
JOB_AGENT_REGISTRATION_CODE=
# Or set to true to allow anyone to register (localhost only - never when exposed)
JOB_AGENT_ALLOW_OPEN_REGISTRATION=false
