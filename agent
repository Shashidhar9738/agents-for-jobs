"[$timestamp] Setup completed" | Out-File -FilePath $Marker -Encoding UTF8
"[$timestamp] Setup completed" | Out-File -FilePath $LogFile -Append -Encoding UTF8

Write-Host ""
Write-Host "================================================" -ForegroundColor Cyan
Write-Host " SETUP COMPLETE" -ForegroundColor Green
